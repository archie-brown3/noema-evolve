# loop machinery: logs stay local, ledgers/goals/prompts are committed
loop/memory/*.log
loop/memory/state-archive/
loop/memory/cron.log
loop/work-order.json

# Experiment output — run dirs are the study's raw data, they live on the
# artefact branch, never on main.
examples/**/runs/
examples/**/openevolve_output*/
examples/**/noema_*output*/
examples/**/best_program.py
examples/**/best_program_info.json
examples/arc_benchmark/outputs/
examples/arc_benchmark/images/
examples/**/evolution_plot.png
examples/**/circle_packing_*.png
examples/**/*.backup
examples/attention_optimization/legacy/
examples/**/*.log

# Dev artefacts
loop/
work-order.json

# NOTE: tests/**/*.log is deliberately NOT ignored — verify_run fixtures are
# real log files the test suite reads (tests/test_verify_run.sh).

*.swp
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv*/
dist/
build/
.pytest_cache/

# Secrets — never commit
.env
.env.*
